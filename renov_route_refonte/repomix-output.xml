interface StructuredDataProps {
  type: 'home' | 'service'
  serviceName?: string
  serviceDescription?: string
  serviceType?: string
}

export default function StructuredData({ 
  type, 
  serviceName, 
  serviceDescription, 
  serviceType 
}: StructuredDataProps) {
  const baseUrl = 'https://renov-route.com'
  
  // Données de l'entreprise (LocalBusiness)
  const localBusiness = {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Renov Route",
    "image": `${baseUrl}/logo.avif`,
    "@id": baseUrl,
    "url": baseUrl,
    "telephone": "+33786819692",
    "email": "contact@renov-route.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "6, allée du ruisseau de Ribbes",
      "addressLocality": "Tassin la demi-lune",
      "postalCode": "69160",
      "addressCountry": "FR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "45.7544",
      "longitude": "4.7719"
    },
    "priceRange": "$$",
    "areaServed": {
      "@type": "Country",
      "name": "France"
    },
    "sameAs": []
  }

  if (type === 'home') {
    return (
      <script
        type="application/ld+json"
        dangerouslySetInnerHTML={{
          __html: JSON.stringify(localBusiness)
        }}
      />
    )
  }

  if (type === 'service' && serviceName && serviceDescription && serviceType) {
    const service = {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": serviceName,
      "description": serviceDescription,
      "provider": localBusiness,
      "areaServed": {
        "@type": "Country",
        "name": "France"
      },
      "serviceType": serviceType
    }

    return (
      <script
        type="application/ld+json"
        dangerouslySetInnerHTML={{
          __html: JSON.stringify(service)
        }}
      />
    )
  }

  return null
}
