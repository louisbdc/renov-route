DirectoryIndex index.html

RewriteEngine On

# Force HTTPS redirect
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Redirections 301 des anciennes URLs vers les nouvelles
# Redirections spécifiques des anciennes URLs du site
RewriteRule ^marquage-routier-lyon-69/?$ /competences/tracage-retracage-parking/ [R=301,L]
RewriteRule ^contact/?$ /qui-sommes-nous/ [R=301,L]
RewriteRule ^blank-1/?$ /competences/resine-sol-marquage-interieur/ [R=301,L]
RewriteRule ^blank/?$ /competences/resine-sol-marquage-interieur/ [R=301,L]
RewriteRule ^peinture-marquage-sol-parking-lyon/?$ /competences/tracage-retracage-parking/ [R=301,L]
RewriteRule ^rebouchage-nids-poules-rhones-alpes/?$ /competences/reparation-nids-de-poule/ [R=301,L]
RewriteRule ^marquage/?$ /competences/tracage-retracage-parking/ [R=301,L]
RewriteRule ^renov-route/?$ /competences/ [R=301,L]
RewriteRule ^home/?$ / [R=301,L]
RewriteRule ^blank-2/?$ /competences/resine-sol-marquage-interieur/ [R=301,L]
RewriteRule ^nos-references/?$ /realisations/ [R=301,L]
RewriteRule ^devis-gratuit/?$ /devis/ [R=301,L]
RewriteRule ^devis-tracage-gratuit/?$ /devis/ [R=301,L]
RewriteRule ^services/renovation-parking/?$ /competences/ [R=301,L]
RewriteRule ^auvergne-rhone-alpes/?$ /competences/ [R=301,L]

# Anciennes URLs realisations avec parametre ?project=
RewriteCond %{QUERY_STRING} (?:^|&)project=([a-z0-9-]+) [NC]
RewriteRule ^realisations/?$ /realisations/%1/? [R=301,L]

# Redirections géographiques vers les compétences correspondantes
# IMPORTANT: Exclure les sections actuelles (/guides/, /competences/, etc.)
# pour ne pas rediriger les nouvelles URLs vers les anciennes
RewriteCond %{REQUEST_URI} !^/guides/
RewriteCond %{REQUEST_URI} !^/competences/
RewriteCond %{REQUEST_URI} !^/devis/
RewriteCond %{REQUEST_URI} !^/realisations/
RewriteCond %{REQUEST_URI} !^/qui-sommes-nous/
RewriteCond %{REQUEST_URI} !^/marquage-au-sol-lyon/
RewriteRule ^marquage-parking-([^/]+)/?$ /competences/tracage-retracage-parking/ [R=301,L]

RewriteCond %{REQUEST_URI} !^/guides/
RewriteCond %{REQUEST_URI} !^/competences/
RewriteCond %{REQUEST_URI} !^/devis/
RewriteCond %{REQUEST_URI} !^/realisations/
RewriteCond %{REQUEST_URI} !^/qui-sommes-nous/
RewriteRule ^tracage-parking-([^/]+)/?$ /competences/tracage-retracage-parking/ [R=301,L]

RewriteCond %{REQUEST_URI} !^/guides/
RewriteCond %{REQUEST_URI} !^/competences/
RewriteCond %{REQUEST_URI} !^/devis/
RewriteCond %{REQUEST_URI} !^/realisations/
RewriteCond %{REQUEST_URI} !^/qui-sommes-nous/
RewriteRule ^marquage-routier-([^/]+)/?$ /competences/tracage-retracage-parking/ [R=301,L]

RewriteCond %{REQUEST_URI} !^/guides/
RewriteCond %{REQUEST_URI} !^/competences/
RewriteCond %{REQUEST_URI} !^/devis/
RewriteCond %{REQUEST_URI} !^/realisations/
RewriteCond %{REQUEST_URI} !^/qui-sommes-nous/
RewriteRule ^reparation-nids-poule-([^/]+)/?$ /competences/reparation-nids-de-poule/ [R=301,L]

RewriteCond %{REQUEST_URI} !^/guides/
RewriteCond %{REQUEST_URI} !^/competences/
RewriteCond %{REQUEST_URI} !^/devis/
RewriteCond %{REQUEST_URI} !^/realisations/
RewriteCond %{REQUEST_URI} !^/qui-sommes-nous/
RewriteRule ^signalisation-([^/]+)/?$ /competences/signalisation-verticale/ [R=301,L]

RewriteCond %{REQUEST_URI} !^/guides/
RewriteCond %{REQUEST_URI} !^/competences/
RewriteCond %{REQUEST_URI} !^/devis/
RewriteCond %{REQUEST_URI} !^/realisations/
RewriteCond %{REQUEST_URI} !^/qui-sommes-nous/
RewriteRule ^accessoires-parking-([^/]+)/?$ /competences/accessoires-parking/ [R=301,L]

RewriteCond %{REQUEST_URI} !^/guides/
RewriteCond %{REQUEST_URI} !^/competences/
RewriteCond %{REQUEST_URI} !^/devis/
RewriteCond %{REQUEST_URI} !^/realisations/
RewriteCond %{REQUEST_URI} !^/qui-sommes-nous/
RewriteRule ^resine-sol-([^/]+)/?$ /competences/resine-sol-marquage-interieur/ [R=301,L]

RewriteCond %{REQUEST_URI} !^/guides/
RewriteCond %{REQUEST_URI} !^/competences/
RewriteCond %{REQUEST_URI} !^/devis/
RewriteCond %{REQUEST_URI} !^/realisations/
RewriteCond %{REQUEST_URI} !^/qui-sommes-nous/
RewriteRule ^conseil-expertise-([^/]+)/?$ /competences/conseil-expertise/ [R=301,L]

# Redirections d'anciens formats d'URL
RewriteRule ^index\.html?$ / [R=301,L]
RewriteRule ^home\.html?$ / [R=301,L]
RewriteRule ^accueil\.html?$ / [R=301,L]
RewriteRule ^services\.html?$ /competences/ [R=301,L]
RewriteRule ^prestations\.html?$ /competences/ [R=301,L]
RewriteRule ^nos-services\.html?$ /competences/ [R=301,L]
RewriteRule ^about\.html?$ /qui-sommes-nous/ [R=301,L]
RewriteRule ^a-propos\.html?$ /qui-sommes-nous/ [R=301,L]
RewriteRule ^equipe\.html?$ /qui-sommes-nous/ [R=301,L]
RewriteRule ^portfolio\.html?$ /realisations/ [R=301,L]
RewriteRule ^projets\.html?$ /realisations/ [R=301,L]
RewriteRule ^galerie\.html?$ /realisations/ [R=301,L]
RewriteRule ^travaux\.html?$ /realisations/ [R=301,L]
RewriteRule ^demande-devis\.html?$ /devis/ [R=301,L]
RewriteRule ^estimation\.html?$ /devis/ [R=301,L]

# Handle client-side routing for Next.js static export
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.html [L]

# Force UTF-8 encoding for text-based files
AddDefaultCharset UTF-8
AddCharset UTF-8 .txt .html .htm .css .js .xml .json .svg

# Security headers
Header always set X-Frame-Options "DENY"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), browsing-topics=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

# Content Security Policy
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob: https://www.googletagmanager.com https://www.google-analytics.com https://maps.gstatic.com https://maps.googleapis.com; connect-src 'self' https: https://www.googletagmanager.com https://www.google-analytics.com https://analytics.google.com; frame-src 'self' https://www.google.com https://maps.google.com; object-src 'none'; base-uri 'self'; form-action 'self' https://api.emailjs.com; frame-ancestors 'none'; upgrade-insecure-requests"

# Cache control
<FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
</FilesMatch>

<FilesMatch "\.(js|css|png|jpg|jpeg|avif|webp|svg|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>